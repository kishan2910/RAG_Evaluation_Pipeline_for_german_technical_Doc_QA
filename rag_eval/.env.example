# =============================================================================
# Embedding model  (OpenAI-compatible /v1/embeddings)
# =============================================================================
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text

# Additional embedding models for multi-run experiments (optional)
# EMBEDDING_BASE_URL_2=http://localhost:11434/v1
# EMBEDDING_API_KEY_2=ollama
# EMBEDDING_MODEL_2=bge-m3

# =============================================================================
# Chat model  (OpenAI-compatible /v1/chat/completions)
# =============================================================================
CHAT_BASE_URL=http://localhost:11434/v1
CHAT_API_KEY=ollama
CHAT_MODEL=qwen2.5:14b-instruct

# Additional chat models for multi-run experiments (optional)
# CHAT_BASE_URL_2=http://localhost:11434/v1
# CHAT_API_KEY_2=ollama
# CHAT_MODEL_2=gemma4-31b

# =============================================================================
# Judge model for DeepEval scoring  (defaults to CHAT model if unset)
# =============================================================================
# JUDGE_BASE_URL=http://localhost:11434/v1
# JUDGE_API_KEY=ollama
# JUDGE_MODEL=qwen3-coder-30b-a3b-instruct

# Additional judge models for multi-run experiments (optional)
# JUDGE_BASE_URL_2=http://localhost:11434/v1
# JUDGE_API_KEY_2=ollama
# JUDGE_MODEL_2=another-judge-model

# =============================================================================
# Paths
# =============================================================================
PDF_DIR=../data
EVAL_CSV=../data/VDE_FNN_Benchmark.csv
CHROMA_DIR=./chroma_db
COLLECTION=vde_fnn

# =============================================================================
# Chunking
# =============================================================================
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# =============================================================================
# Retrieval / generation
# =============================================================================
TOP_K=5
EMBED_BATCH_SIZE=32
CHAT_MAX_TOKENS=512
CHAT_TEMPERATURE=0.0
REQUEST_TIMEOUT=120
EVAL_CONCURRENCY=5

# =============================================================================
# MLflow tracking
# =============================================================================
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT=rag_eval
