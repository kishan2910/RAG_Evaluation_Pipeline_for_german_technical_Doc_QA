# Embedding endpoint (OpenAI-compatible /v1/embeddings).
# Typical local choices: ollama (nomic-embed-text, mxbai-embed-large),
# llama.cpp embedding server, vLLM with an embedding model loaded.
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text

# Chat endpoint (OpenAI-compatible /v1/chat/completions).
CHAT_BASE_URL=http://localhost:11434/v1
CHAT_API_KEY=ollama
CHAT_MODEL=qwen2.5:14b-instruct

# Judge endpoint — only used by `test_rag.py eval`. If unset, defaults to CHAT.
# JUDGE_BASE_URL=
# JUDGE_API_KEY=
# JUDGE_MODEL=

# Paths
PDF_DIR=./data
EVAL_CSV=./data/VDE_FNN_Benchmark.csv
CHROMA_DIR=./rag/chroma_db
COLLECTION=vde_fnn

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Retrieval / generation
TOP_K=5
EMBED_BATCH_SIZE=32
CHAT_MAX_TOKENS=512
CHAT_TEMPERATURE=0.0
REQUEST_TIMEOUT=120
